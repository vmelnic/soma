{
  "schema_version": "1.0",
  "plugin": "timer",
  "plugin_version": "0.1.0",
  "examples": [
    {
      "id": "timer_set_timeout_001",
      "intents": [
        "set a {delay} second timer",
        "set a timer for {delay} seconds",
        "start a {delay}s timeout",
        "fire once after {delay} seconds",
        "create a one-shot timer for {delay} seconds"
      ],
      "program": [
        {"convention": "timer.set_timeout", "args": [{"name": "label", "type": "literal", "value": "timer"}, {"name": "delay_ms", "type": "span", "extract": "delay_ms"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "delay": ["5", "10", "30", "60", "120"]
      },
      "tags": ["timer", "timeout", "delay", "one-shot"]
    },
