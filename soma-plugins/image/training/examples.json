        {"convention": "image.thumbnail", "args": [{"name": "data", "type": "span", "extract": "data"}, {"name": "width", "type": "span", "extract": "width"}, {"name": "height", "type": "span", "extract": "height"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "width": [100, 150, 200, 256, 320],
        "height": [100, 150, 200, 256, 320]
      },
      "tags": ["image", "thumbnail", "resize"]
    },
