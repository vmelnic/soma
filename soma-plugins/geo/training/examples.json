      ],
      "program": [
        {"convention": "geo.bounding_box", "args": [{"name": "radius_km", "type": "span", "extract": "radius"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "radius": ["1", "5", "10", "25", "100"]
      },
      "tags": ["geo", "bounding_box", "bounds", "optimization"]
