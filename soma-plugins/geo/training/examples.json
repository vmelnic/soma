      "program": [
        {"convention": "geo.within_radius", "args": [{"name": "radius_km", "type": "span", "extract": "radius"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "radius": ["1", "5", "10", "25", "50"]
      },
      "tags": ["geo", "radius", "filter", "nearby"]
