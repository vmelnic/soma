{
  "schema_version": "1.0",
  "plugin": "geo",
  "plugin_version": "0.1.0",
  "examples": [
    {
      "id": "geo_distance_001",
      "intents": [
        "how far is {location1} from {location2}",
        "calculate distance between {location1} and {location2}",
        "what's the distance from {location1} to {location2}",
        "distance between {location1} and {location2}",
        "how many km from {location1} to {location2}",
        "measure the distance from {location1} to {location2}"
      ],
      "program": [
        {"convention": "geo.distance", "args": [{"name": "from", "type": "span", "extract": "location1"}, {"name": "to", "type": "span", "extract": "location2"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "location1": ["downtown", "city center", "the office", "home", "the airport"],
        "location2": ["the park", "the mall", "school", "the station", "the hospital"]
      },
      "tags": ["geo", "distance", "haversine"]
    },
    {
      "id": "geo_distance_002",
      "intents": [
        "how far apart are these two coordinates",
        "get the haversine distance",
        "compute great circle distance",
        "what is the straight line distance between these points",
        "calculate km between two GPS coordinates"
      ],
      "program": [
        {"convention": "geo.distance", "args": [{"name": "lat1", "type": "span", "extract": "lat1"}, {"name": "lon1", "type": "span", "extract": "lon1"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {},
      "tags": ["geo", "distance", "haversine", "gps"]
    },
    {
