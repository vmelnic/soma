        {"convention": "geo.bounding_box", "args": []},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {},
      "tags": ["geo", "bounding_box", "spatial"]
    },
