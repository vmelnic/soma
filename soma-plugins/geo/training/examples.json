    },
    {
      "id": "geo_bbox_and_filter_001",
      "intents": [
        "get bounding box then filter points within {radius}km",
        "optimize a radius search for {radius}km",
        "pre-filter with bounding box for a {radius}km search"
      ],
      "program": [
        {"convention": "geo.bounding_box", "args": [{"name": "radius_km", "type": "span", "extract": "radius"}]},
        {"convention": "geo.within_radius", "args": [{"name": "radius_km", "type": "span", "extract": "radius"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 1}]},
        {"convention": "STOP"}
      ],
      "params": {
        "radius": ["5", "10", "25", "50", "100"]
      },
      "tags": ["geo", "bounding_box", "radius", "optimization", "multi-step"]
