{
  "schema_version": "1.0",
  "plugin": "s3",
  "plugin_version": "0.1.0",
  "examples": [
    {
      "id": "s3_put_object_001",
      "intents": [
        "upload this file to S3",
        "store {filename} in S3 bucket {bucket}",
        "put this data in S3",
        "upload {filename} to cloud storage",
        "save {filename} to the {bucket} bucket",
        "push this file to S3 storage"
      ],
      "program": [
        {"convention": "s3.put_object", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "filename"}, {"name": "data", "type": "ref", "step": -1}, {"name": "content_type", "type": "literal", "value": "application/octet-stream"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "filename": ["report.pdf", "photo.jpg", "backup.tar.gz", "data.csv", "document.docx"],
        "bucket": ["uploads", "backups", "media", "documents", "soma-uploads"]
      },
      "tags": ["s3", "upload", "put", "storage"]
    },
    {
      "id": "s3_put_object_002",
      "intents": [
        "upload the profile photo to storage",
        "store the user avatar in the media bucket",
        "save the image to S3 as {key}",
        "upload the attachment to the {bucket} bucket",
        "write this binary data to S3"
      ],
      "program": [
        {"convention": "s3.put_object", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "key"}, {"name": "data", "type": "ref", "step": -1}, {"name": "content_type", "type": "span", "extract": "content_type"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["media", "avatars", "attachments", "uploads"],
        "key": ["avatars/user-123.jpg", "photos/profile.png", "docs/invoice.pdf"],
        "content_type": ["image/jpeg", "image/png", "application/pdf", "application/octet-stream"]
      },
      "tags": ["s3", "upload", "put", "media", "image"]
    },
    {
      "id": "s3_get_object_001",
      "intents": [
        "download the profile photo from S3",
        "get {key} from the {bucket} bucket",
        "fetch the file from S3 storage",
        "retrieve {key} from cloud storage",
        "download {key} from S3",
        "read the object from S3"
      ],
      "program": [
        {"convention": "s3.get_object", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "key"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["uploads", "media", "backups", "soma-uploads"],
        "key": ["avatars/user-123.jpg", "reports/monthly.pdf", "data/export.csv", "photos/profile.png"]
      },
      "tags": ["s3", "download", "get", "fetch", "storage"]
    },
    {
      "id": "s3_get_object_002",
      "intents": [
        "get the latest backup from storage",
        "download the export file",
        "retrieve the uploaded document",
        "fetch the attachment from the bucket",
        "pull the image from S3"
      ],
      "program": [
        {"convention": "s3.get_object", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "key"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["backups", "exports", "documents", "attachments"],
        "key": ["latest/backup.tar.gz", "exports/data.csv", "docs/contract.pdf"]
      },
      "tags": ["s3", "download", "get", "retrieve"]
    },
    {
      "id": "s3_delete_object_001",
      "intents": [
        "delete the old backup from storage",
        "remove {key} from the {bucket} bucket",
        "delete {key} from S3",
        "clean up the file from cloud storage",
        "remove the expired upload from S3",
        "delete the temporary file from storage"
      ],
      "program": [
        {"convention": "s3.delete_object", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "key"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["uploads", "backups", "temp", "soma-uploads"],
        "key": ["old/backup-2024.tar.gz", "temp/upload-abc123.tmp", "expired/session-data.bin"]
      },
      "tags": ["s3", "delete", "remove", "cleanup", "storage"]
    },
    {
      "id": "s3_delete_object_002",
      "intents": [
        "purge the user's uploaded avatar",
        "remove the outdated report from S3",
        "delete the orphaned attachment",
        "clean up expired files in the bucket",
        "remove this object from storage"
      ],
      "program": [
        {"convention": "s3.delete_object", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "key"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["avatars", "reports", "attachments"],
        "key": ["users/old-avatar.jpg", "monthly/2023-01.pdf", "orphaned/file.bin"]
      },
      "tags": ["s3", "delete", "remove", "purge"]
    },
    {
      "id": "s3_presign_url_001",
      "intents": [
        "get a download link for the report",
        "generate a presigned URL for {key}",
        "create a temporary download link for the file",
        "give me a shareable link for {key} in {bucket}",
        "get a signed URL that expires in {expires} seconds",
        "create a time-limited access URL for {key}"
      ],
      "program": [
        {"convention": "s3.presign_url", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "key"}, {"name": "expires_secs", "type": "span", "extract": "expires"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["uploads", "reports", "media", "soma-uploads"],
        "key": ["reports/quarterly.pdf", "invoices/2024-03.pdf", "exports/data.csv"],
        "expires": ["300", "900", "3600", "86400"]
      },
      "tags": ["s3", "presign", "url", "share", "download"]
    },
    {
      "id": "s3_presign_url_002",
      "intents": [
        "make a temporary link for the user to download their file",
        "generate a one-hour download URL",
        "presign a URL so the client can fetch the image directly",
        "create an expiring link for this S3 object",
        "get a pre-authenticated URL for the attachment"
      ],
      "program": [
        {"convention": "s3.presign_url", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "key", "type": "span", "extract": "key"}, {"name": "expires_secs", "type": "literal", "value": "3600"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["media", "attachments", "downloads"],
        "key": ["user-files/doc.pdf", "images/photo.jpg", "exports/report.xlsx"]
      },
      "tags": ["s3", "presign", "url", "temporary", "access"]
    },
    {
      "id": "s3_list_objects_001",
      "intents": [
        "list all files in the uploads folder",
        "show files in the {bucket} bucket under {prefix}",
        "list objects in S3 with prefix {prefix}",
        "what files are in the {bucket} bucket",
        "list the contents of the {prefix} directory in S3",
        "enumerate files in storage under {prefix}"
      ],
      "program": [
        {"convention": "s3.list_objects", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "prefix", "type": "span", "extract": "prefix"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["uploads", "backups", "media", "soma-uploads"],
        "prefix": ["uploads/", "photos/", "reports/2024/", "backups/daily/", ""]
      },
      "tags": ["s3", "list", "browse", "directory", "storage"]
    },
    {
      "id": "s3_list_objects_002",
      "intents": [
        "show me all the images in the media bucket",
        "browse the backup files in storage",
        "list everything in the documents folder on S3",
        "find all objects matching this prefix",
        "what objects exist in this S3 path"
      ],
      "program": [
        {"convention": "s3.list_objects", "args": [{"name": "bucket", "type": "span", "extract": "bucket"}, {"name": "prefix", "type": "span", "extract": "prefix"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "bucket": ["media", "backups", "documents"],
        "prefix": ["images/", "daily/", "user-docs/", ""]
      },
      "tags": ["s3", "list", "browse", "find", "objects"]
    }
  ]
}
