        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "table": ["users", "contacts", "appointments", "messages", "reviews"]
      },
      "tags": ["postgres", "query", "select"]
    },
