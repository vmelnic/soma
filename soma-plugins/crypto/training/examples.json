        "generate a signed JWT",
        "make a JSON web token",
        "issue a JWT for these claims",
        "sign a JWT with HS256"
      ],
      "program": [
        {"convention": "crypto.jwt_sign", "args": [{"name": "claims", "type": "span", "extract": "claims"}, {"name": "secret", "type": "span", "extract": "secret"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "claims": ["{\"sub\":\"user1\",\"role\":\"admin\"}", "{\"sub\":\"service\",\"iat\":1700000000}", "{\"user_id\":42,\"scope\":\"read\"}"],
        "secret": ["my-secret-key", "jwt-signing-key-2024"]
      },
      "tags": ["crypto", "jwt", "token"]
    },
    {
      "id": "crypto_jwt_verify_001",
      "intents": [
