{
  "schema_version": "1.0",
  "plugin": "crypto",
  "plugin_version": "0.1.0",
  "examples": [
    {
      "id": "crypto_sha256_001",
      "intents": [
        "hash {data}",
        "compute SHA256 of {data}",
        "get the SHA-256 hash of {data}",
        "sha256 hash {data}",
        "calculate hash for {data}",
        "generate SHA256 digest of {data}"
      ],
      "program": [
        {"convention": "crypto.hash_sha256", "args": [{"name": "data", "type": "span", "extract": "data"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "data": ["hello", "password123", "test data", "secret message", "my file content"]
      },
      "tags": ["crypto", "hash", "sha256"]
    },
    {
      "id": "crypto_argon2_001",
      "intents": [
        "hash password {password}",
        "securely hash {password}",
        "create password hash for {password}",
        "argon2 hash {password}",
        "hash {password} with argon2",
        "generate a secure hash of password {password}"
      ],
      "program": [
        {"convention": "crypto.hash_argon2", "args": [{"name": "password", "type": "span", "extract": "password"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "password": ["hunter2", "s3cret!", "MyP@ssw0rd", "correcthorsebatterystaple", "admin123"]
      },
      "tags": ["crypto", "hash", "argon2", "password"]
    },
    {
      "id": "crypto_verify_argon2_001",
      "intents": [
        "verify password {password} against hash",
        "check if {password} matches the hash",
        "validate password {password}",
        "does {password} match this argon2 hash",
        "verify argon2 hash for {password}",
        "check password {password} against stored hash"
      ],
      "program": [
        {"convention": "crypto.verify_argon2", "args": [{"name": "password", "type": "span", "extract": "password"}, {"name": "hash", "type": "span", "extract": "hash"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "password": ["hunter2", "s3cret!", "MyP@ssw0rd", "correcthorsebatterystaple", "admin123"],
        "hash": ["$argon2id$v=19$m=19456,t=2,p=1$EXAMPLE_SALT$EXAMPLE_HASH"]
      },
      "tags": ["crypto", "hash", "argon2", "password", "verify"]
    },
    {
