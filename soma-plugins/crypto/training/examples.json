      "program": [
        {"convention": "crypto.jwt_verify", "args": [{"name": "token", "type": "span", "extract": "token"}, {"name": "secret", "type": "span", "extract": "secret"}]},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {
        "token": ["eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyMSJ9.EXAMPLE"],
        "secret": ["my-secret-key", "jwt-signing-key-2024"]
      },
      "tags": ["crypto", "jwt", "token", "verify"]
    },
