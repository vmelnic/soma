      "program": [
        {"convention": "crypto.random_bytes", "args": [{"name": "count", "type": "literal", "value": 32}]},
        {"convention": "crypto.encrypt_aead", "args": [{"name": "plaintext", "type": "span", "extract": "data"}, {"name": "key", "type": "ref", "step": 0}]},
