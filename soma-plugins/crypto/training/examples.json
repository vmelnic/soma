      "program": [
        {"convention": "crypto.random_uuid", "args": []},
        {"convention": "EMIT", "args": [{"name": "data", "type": "ref", "step": 0}]},
        {"convention": "STOP"}
      ],
      "params": {},
      "tags": ["crypto", "random", "uuid"]
    },
