# Per-board serial port assignments. Edit these once for your machine.
#
# All scripts in this directory source this file at startup. Override at the
# command line by exporting the same vars before invoking a script:
#
#   ESP32S3_PORT=/dev/cu.usbserial-XYZW ./scripts/flash.sh esp32s3

# ESP32-S3 (e.g. Sunton 1732S019, ESP32-S3-DevKitM-1)
ESP32S3_PORT=/dev/cu.usbserial-110

# ESP32 / WROOM-32 / WROOM-32D (e.g. 18650/OLED dev boards)
ESP32_PORT=/dev/cu.usbserial-0001

# Add new chip ports here as you bring them up:
# ESP32C3_PORT=/dev/cu.usbmodemXXXX
# ESP32C6_PORT=/dev/cu.usbmodemYYYY
# ESP32S2_PORT=/dev/cu.usbserial-ZZZZ
