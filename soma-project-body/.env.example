# ─── SOMA Runtime ────────────────────────────────────────────────
SOMA_WS_TOKEN=change-me-in-production
SOMA_SOMA_DATA_DIR=./data

# ─── Docker: host ports ─────────────────────────────────────────
POSTGRES_PORT=5432
REDIS_PORT=6379
MONGODB_PORT=27017
MYSQL_PORT=3306
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
SMTP_PORT=1025
SMTP_WEB_PORT=1080

# ─── Database: PostgreSQL ────────────────────────────────────────
POSTGRES_DB=soma
POSTGRES_USER=soma
POSTGRES_PASSWORD=soma
SOMA_POSTGRES_URL=host=localhost port=${POSTGRES_PORT} dbname=${POSTGRES_DB} user=${POSTGRES_USER} password=${POSTGRES_PASSWORD}

# ─── Database: Redis ─────────────────────────────────────────────
SOMA_REDIS_URL=redis://localhost:${REDIS_PORT}/0

# ─── Database: MongoDB ───────────────────────────────────────────
SOMA_MONGODB_URL=mongodb://localhost:${MONGODB_PORT}
SOMA_MONGODB_DATABASE=soma

# ─── Database: MySQL ─────────────────────────────────────────────
MYSQL_DATABASE=soma
MYSQL_USER=soma
MYSQL_PASSWORD=soma
MYSQL_ROOT_PASSWORD=root
SOMA_MYSQL_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@localhost:${MYSQL_PORT}/${MYSQL_DATABASE}

# ─── Object Storage: S3 / MinIO ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
SOMA_S3_ENDPOINT=http://localhost:${MINIO_PORT}
SOMA_S3_DEFAULT_BUCKET=soma-uploads
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_REGION=us-east-1

# ─── Email: SMTP ─────────────────────────────────────────────────
# Docker: mailcatcher (no auth, web UI on SMTP_WEB_PORT)
SOMA_SMTP_HOST=localhost
SOMA_SMTP_PORT=${SMTP_PORT}
SOMA_SMTP_FROM=soma@localhost
SOMA_SMTP_STARTTLS=false
# For production (e.g. SendGrid, Gmail):
# SOMA_SMTP_HOST=smtp.sendgrid.net
# SOMA_SMTP_PORT=587
# SOMA_SMTP_USERNAME=apikey
# SOMA_SMTP_PASSWORD=SG.your-sendgrid-key
# SOMA_SMTP_FROM=noreply@yourdomain.com
# SOMA_SMTP_STARTTLS=true

# ─── Google APIs (live credentials, no Docker) ───────────────────
#SOMA_GOOGLE_ACCESS_TOKEN=ya29.your-token-here

# ─── Slack (live credentials) ────────────────────────────────────
#SOMA_SLACK_BOT_TOKEN=xoxb-your-bot-token
#SOMA_SLACK_DEFAULT_CHANNEL=general

# ─── Stripe (live credentials) ───────────────────────────────────
#SOMA_STRIPE_SECRET_KEY=sk_test_your-key

# ─── Twilio (live credentials) ───────────────────────────────────
#SOMA_TWILIO_ACCOUNT_SID=AC...
#SOMA_TWILIO_AUTH_TOKEN=your-auth-token
#SOMA_TWILIO_FROM_NUMBER=+15551234567

# ─── Elasticsearch (optional, uncomment in docker-compose too) ───
#ELASTICSEARCH_PORT=9200
#SOMA_ELASTICSEARCH_URL=http://localhost:${ELASTICSEARCH_PORT}

# ─── Push notifications (live credentials) ───────────────────────
#SOMA_PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
#SOMA_PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key
