  "runtime_compatibility": ">=0.1.0",
  "namespace": "soma.project.terminal",
  "description": "Platform pack for soma-project-terminal. Loads crypto + postgres + smtp ports so every side effect in the backend (token hashing, random string generation, user/session/magic_token persistence, magic-link email delivery) goes through soma-next via MCP invoke_port.",
