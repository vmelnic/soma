    {
      "group_name": "crypto",
      "scope": "local",
      "capabilities": [
        "sha256",
        "random_string"
      ]
    },
    {
      "group_name": "database",
      "scope": "local",
      "capabilities": [
        "query",
        "execute",
        "insert",
        "update",
        "find",
        "find_many",
        "count"
      ]
    },
    {
      "group_name": "email",
      "scope": "local",
      "capabilities": [
        "send_plain",
        "send_html"
      ]
    }
  ],
