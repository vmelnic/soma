# soma-project-terminal dev environment.
#
# Copy to .env and adjust. .env is gitignored via the root
# .gitignore's **/.env pattern.
#
# Every runtime side effect (Postgres, SMTP, crypto) goes through
# soma-next via MCP. The env vars below are what the spawned
# soma-next process reads — see building-projects.md for the
# convention each port uses.

# ---- Backend HTTP port --------------------------------------------
BACKEND_PORT=8765

# ---- Public base URL used in magic-link emails --------------------
PUBLIC_BASE_URL=http://localhost:8765

# ---- Session / magic-token lifetimes ------------------------------
SESSION_TTL_DAYS=30
MAGIC_TOKEN_TTL_MINUTES=15

# ---- soma-ports/postgres environment ------------------------------
# The postgres port reads this on init.
SOMA_POSTGRES_URL=postgres://soma:soma@localhost:5433/soma_terminal

# ---- soma-ports/smtp environment ----------------------------------
# Mailcatcher in dev (no auth, no TLS). Swap for a real provider in prod.
SOMA_SMTP_HOST=localhost
SOMA_SMTP_PORT=1025
SOMA_SMTP_USERNAME=
SOMA_SMTP_PASSWORD=
SOMA_SMTP_FROM=soma-terminal@localhost
# Mailcatcher doesn't speak STARTTLS. Set to "true" for real providers.
SOMA_SMTP_STARTTLS=false

# ---- OpenAI — conversational brain (tool-calling) + Whisper --------
OPENAI_API_KEY=sk-...

# The chat brain. backend/brain.mjs auto-detects which family the
# model belongs to and sends the right parameters:
#
#   - Chat family (gpt-4o-mini, gpt-4o, gpt-4, gpt-3.5-turbo):
#       uses `temperature` + `max_tokens`.
#       Cheaper and faster, weaker at multi-step tool planning.
#
#   - Reasoning family (gpt-5-mini, gpt-5, o1, o1-mini, o3, o3-mini):
#       uses `reasoning_effort="low"` + `max_completion_tokens`.
#       A bit slower (few extra seconds) and more expensive, but
#       noticeably better at knowing when to stop tool-calling and
#       actually answer. Recommended if you see the chat brain
#       looping through tool calls and hitting the cap.
#
# Flip between them freely — no other code change needed.
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CHAT_MODEL=gpt-5-mini

# ---- Brain mode ----------------------------------------------------
# Set BRAIN_FAKE=1 to bypass OpenAI entirely and return deterministic
# canned responses (echo reply for chat, byte-count echo for
# transcribe). Useful for CI hermetic runs and for dev iteration
# when you don't want to burn API quota. Tests also use a ::tool
# escape trigger in fake mode to drive tool calls deterministically
# against the real soma-next subprocess — see tests/chat.spec.js.
# Leave BRAIN_FAKE empty (or unset) to hit real OpenAI with the key
# above. Playwright tests always force BRAIN_FAKE=1 via webServer
# env, so leaving this unset in .env is safe for local-real +
# tests-fake.
BRAIN_FAKE=
