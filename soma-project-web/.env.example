# soma-project-web brain-proxy configuration.
#
# Copy this file to `.env` and fill in your key, then run:
#   ./scripts/run-brain.sh
# or equivalently:
#   node --env-file=.env scripts/brain-proxy.mjs
#
# `.env` is gitignored globally (repo root .gitignore has `**/.env`),
# so your key will never be committed. `.env.example` (this file) is
# safe to commit because it contains no secrets.

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: override the default model. Leave commented to use gpt-5-mini.
# OPENAI_MODEL=gpt-5

# Optional: override the default port. Leave commented to use 8787.
# BRAIN_PROXY_PORT=8787
