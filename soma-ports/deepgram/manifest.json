          "input_schema": {
            "schema": {
              "type": "object",
              "required": ["url"],
              "properties": {
                "url": { "type": "string", "description": "URL of audio file to transcribe" },
                "model": { "type": "string", "description": "Model to use (e.g. nova-3, base)" },
                "language": { "type": "string", "description": "BCP-47 language code" },
                "punctuate": { "type": "boolean" },
                "diarize": { "type": "boolean", "description": "Enable speaker diarization" },
                "smart_format": { "type": "boolean", "description": "Enable smart formatting (dates, currency, etc.)" },
                "utterances": { "type": "boolean" },
                "paragraphs": { "type": "boolean" },
                "summarize": { "type": ["boolean", "string"], "description": "Enable summarization (true or 'v2')" },
                "topics": { "type": "boolean" },
                "intents": { "type": "boolean" },
                "sentiment": { "type": "boolean" },
                "detect_language": { "type": "boolean" },
                "redact": { "type": "array", "items": { "type": "string" }, "description": "PII types to redact" },
                "search": { "type": "array", "items": { "type": "string" }, "description": "Terms to search for in audio" },
                "keywords": { "type": "array", "items": { "type": "string" }, "description": "Keywords to boost recognition" },
                "multichannel": { "type": "boolean" },
                "alternatives": { "type": "integer" },
                "numerals": { "type": "boolean" },
                "profanity_filter": { "type": "boolean" },
                "tag": { "type": "string" }
              }
            }
          },
          "output_schema": {
            "schema": {
              "type": "object",
              "properties": {
                "metadata": { "type": "object" },
                "results": { "type": "object" }
              }
            }
          },
          "effect_class": "read_only",
          "rollback_support": "irreversible",
          "determinism_class": "stochastic",
          "idempotence_class": "idempotent",
          "risk_class": "low",
          "latency_profile": { "expected_latency_ms": 500, "p95_latency_ms": 5000, "max_latency_ms": 120000 },
          "cost_profile": { "cpu_cost_class": "low", "memory_cost_class": "low", "io_cost_class": "low", "network_cost_class": "medium", "energy_cost_class": "low" },
          "remote_exposable": false
